# Banter's own auth (independent of the PM app)
BANTER_AUTH_SECRET=replace-with-a-long-random-string

# Durable JSON store on Vercel (required in production so signups survive logout/cold starts)
# Created via: vercel blob create-store banter-data --access private --yes
BLOB_READ_WRITE_TOKEN=

# Shared Firebase project with the PM tool (Auth + Firestore)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# PM app URL (deep links / Open PM)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PM_APP_URL=http://localhost:3001

# Banterlina AI assistant (OpenAI-compatible)
OPENAI_API_KEY=
# BANTERLINA_API_KEY=
# BANTERLINA_BASE_URL=https://api.openai.com/v1
# BANTERLINA_MODEL=gpt-4o-mini

# Optional task webhooks from PM
# PM_WEBHOOK_SECRET=replace-with-a-long-random-string
